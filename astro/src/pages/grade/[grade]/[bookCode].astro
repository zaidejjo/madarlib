---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BookDetailBlock from '../../../components/BookDetailBlock.astro';
import PdfPreviewModal from '../../../components/PdfPreviewModal.astro';

export async function getStaticPaths() {
  const { grades } = await import('../../../data/books.json');
  const paths = [];
  for (const grade of grades) {
    for (const book of grade.books || []) {
      paths.push({
        params: { grade: String(grade.number), bookCode: book.code },
        props: { grade, book },
      });
    }
  }
  return paths;
}

const { grade, book } = Astro.props;
const accentColor = grade.accentColor || 'cyan';
const semesterCount = book.semesters?.length || 0;
---

<BaseLayout
  title={`مكتبة مدار | ${book.subject} — الصف ${grade.nameArabic}`}
  description={`تحميل كتاب ${book.subject} للصف ${grade.nameArabic} — كتاب الطالب وكتاب التمارين للفصلين الدراسيين`}
  canonicalSlug={`/grade/${grade.number}/${book.code}`}
>
  <!-- ════════════════════════════════════════════════════
       HERO — Book identity with dynamic accent glow
       ════════════════════════════════════════════════════ -->
  <section class="relative pt-32 pb-8 sm:pt-40 sm:pb-8 md:pt-48 md:pb-8 px-4">
    <div class="max-w-5xl mx-auto">
      <!-- Breadcrumb -->
      <div class="flex items-center gap-2 text-sm text-slate-500 mb-8 entrance-1 font-medium">
        <a href="/" data-astro-prefetch class="hover:text-cyan-400 transition-colors">الرئيسية</a>
        <i class="fa-solid fa-chevron-left text-[10px] text-slate-600"></i>
        <a href={`/grade/${grade.number}`} data-astro-prefetch class="hover:text-cyan-400 transition-colors">الصف {grade.nameArabic}</a>
        <i class="fa-solid fa-chevron-left text-[10px] text-slate-600"></i>
        <span class="text-white/80">{book.subject}</span>
      </div>

      <!-- Book Hero Card -->
      <div class="glass rounded-3xl p-7 sm:p-9 border border-slate-800/50 entrance-2">
        <div class="flex items-center gap-5 sm:gap-8">
          <!-- Icon with dynamic glow shadow -->
          <div class={`w-20 h-20 sm:w-24 sm:h-24 rounded-2xl bg-gradient-to-br ${book.coverGradient} flex items-center justify-center shrink-0 shadow-2xl`}
               style="box-shadow: 0 8px 40px rgba(6, 182, 212, 0.15);">
            <i class={`fa-solid ${book.icon} text-white text-3xl sm:text-4xl`}></i>
          </div>
          <div class="flex-1 min-w-0">
            <h1 class="text-2xl sm:text-3xl md:text-4xl font-black text-white mb-1.5">{book.subject}</h1>
            <p class="text-slate-400 text-sm sm:text-base font-medium mb-3">
              الصف {grade.nameArabic}
            </p>
            <div class="flex flex-wrap gap-2">
              {book.semesters?.map(sem => (
                <span class="px-3 py-1 rounded-full text-xs font-bold bg-slate-800/80 text-slate-300 border border-slate-700/50">
                  {sem.label}
                </span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════
       SEMESTER SECTIONS — Premium dual-action grids
       ════════════════════════════════════════════════════ -->
  <section class="px-4 pb-20 sm:pb-24">
    <div class="max-w-5xl mx-auto space-y-8 sm:space-y-10">
      {book.semesters?.map((sem, idx) => (
        <div class={`entrance-${(idx % 3) + 2}`}>
          <!-- Semester header -->
          <div class="flex items-center gap-3 mb-4 sm:mb-5">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-cyan-500/20 to-indigo-500/20 flex items-center justify-center">
              <i class="fa-solid fa-book text-cyan-400 text-base"></i>
            </div>
            <h2 class="text-xl sm:text-2xl font-bold text-white">{sem.label}</h2>
          </div>

          <!-- Dual book cards side by side -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
            <!-- Student Book -->
            <BookDetailBlock
              bookType="studentBook"
              data={sem.studentBook}
              accentColor={accentColor}
              label="كتاب الطالب"
              icon={book.icon}
              semesterLabel={sem.label}
            />

            <!-- Activity Book -->
            <BookDetailBlock
              bookType="activityBook"
              data={sem.activityBook}
              accentColor={accentColor}
              label="كتاب التمارين"
              icon="fa-pen-to-square"
              semesterLabel={sem.label}
            />
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Back to grade -->
  <section class="px-4 pb-12">
    <div class="max-w-5xl mx-auto text-center">
      <a
        href={`/grade/${grade.number}`}
        data-astro-prefetch
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-bold text-slate-300 border border-slate-700/60 hover:border-cyan-500/30 hover:text-cyan-300 hover:bg-cyan-500/5 active:scale-[0.97] transition-all duration-200"
      >
        <i class="fa-solid fa-arrow-right"></i>
        العودة إلى كتب الصف {grade.nameArabic}
      </a>
    </div>
  </section>

  <!-- PDF Preview Modal -->
  <PdfPreviewModal />
</BaseLayout>
