---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookCard from '../../components/BookCard.astro';

export async function getStaticPaths() {
  const { grades } = await import('../../data/books.json');
  return grades.map(g => ({
    params: { grade: String(g.number) },
    props: { grade: g },
  }));
}

const { grade } = Astro.props;
const accentColor = grade.accentColor || 'cyan';
const bookCount = grade.books?.length || 0;

// Unique subject codes for filter pills
const subjectCodes = [...new Set(grade.books?.map(b => b.code) || [])];
---

<BaseLayout
  title={`مكتبة مدار | الصف ${grade.nameArabic}`}
  description={`جميع كتب الصف ${grade.nameArabic} — تحميل كتب الطالب وكراسات التمارين للفصلين الدراسيين`}
  canonicalSlug={`/grade/${grade.number}`}
>
  <section class="relative pt-32 pb-12 sm:pt-40 sm:pb-16 md:pt-48 md:pb-12 px-4">
    <div class="max-w-6xl mx-auto">
      <!-- Breadcrumb -->
      <div class="flex items-center gap-2 text-sm text-slate-500 mb-8 entrance-1 font-medium">
        <a href="/" data-astro-prefetch class="hover:text-cyan-400 transition-colors">الرئيسية</a>
        <i class="fa-solid fa-chevron-left text-[10px] text-slate-600"></i>
        <span class="text-white/80">الصف {grade.nameArabic}</span>
      </div>

      <!-- Title -->
      <div class="text-right entrance-2">
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-black text-white mb-3">
          الصف <span class="gradient-text">{grade.nameArabic}</span>
        </h1>
        <p class="text-slate-400 text-base sm:text-lg font-medium">
          {bookCount > 0
            ? `${bookCount} كتاب متاح`
            : 'لا توجد كتب متاحة حالياً'}
        </p>
      </div>
    </div>
  </section>

  <!-- Books Grid -->
  <section class="px-4 pb-20 sm:pb-24">
    <div class="max-w-6xl mx-auto">
      {bookCount > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 sm:gap-6">
          {grade.books.map((book, i) => (
            <div class={`entrance-${(i % 7) + 1}`}>
              <BookCard
                subject={book.subject}
                code={book.code}
                icon={book.icon}
                coverGradient={book.coverGradient}
                semesters={book.semesters}
                gradeNumber={grade.number}
              />
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-20">
          <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-slate-800/50 flex items-center justify-center">
            <i class="fa-solid fa-book-open text-slate-600 text-3xl"></i>
          </div>
          <h3 class="text-white text-xl font-bold mb-2">لا توجد كتب متاحة لهذا الصف حالياً</h3>
          <p class="text-slate-500 text-base font-medium mb-8">يرجى التحقق لاحقاً</p>
          <a href="/" data-astro-prefetch class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-bold text-cyan-300 border border-cyan-500/20 hover:bg-cyan-500/10 transition-all duration-200">
            <i class="fa-solid fa-arrow-right"></i>
            العودة إلى الرئيسية
          </a>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
