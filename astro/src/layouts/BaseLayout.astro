---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

export interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalSlug?: string;
}

const { title, description, image, canonicalSlug } = Astro.props;
const site = 'https://madarlib.pages.dev';
const canonicalUrl = canonicalSlug ? `${site}${canonicalSlug}` : site;
const ogImage = image || `${site}/logo.webp`;
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#020617" />
    <meta name="color-scheme" content="dark" />

    <!-- ClientRouter — SPA view transitions -->
    <ClientRouter fallback="swap" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/webp" href="/logo.webp" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Premium Arabic Font: Cairo (variable-like weights) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  </head>
  <body class="antialiased">
    <!-- Ambient orbs -->
    <div class="fixed inset-0 pointer-events-none z-0 overflow-hidden" aria-hidden="true">
      <div class="absolute -top-48 -right-48 w-[32rem] h-[32rem] bg-cyan-500/6 rounded-full blur-[160px]"></div>
      <div class="absolute -bottom-48 -left-48 w-[36rem] h-[36rem] bg-indigo-500/6 rounded-full blur-[180px]"></div>
      <div class="absolute top-1/2 left-1/3 w-64 h-64 bg-violet-500/4 rounded-full blur-[120px]" style="animation-delay: 1.8s;"></div>
    </div>

    <!-- Navbar -->
    <nav class="relative z-50">
      <div class="fixed top-4 left-1/2 -translate-x-1/2 w-[calc(100%-2rem)] max-w-6xl rounded-2xl px-5 py-3 flex items-center justify-between shadow-2xl shadow-black/40"
           style="background: rgba(2, 6, 23, 0.82); backdrop-filter: blur(28px); -webkit-backdrop-filter: blur(28px); border: 1px solid rgba(148, 163, 184, 0.08);">
        <a href="/" class="flex items-center gap-3 group shrink-0">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-cyan-400 to-indigo-600 flex items-center justify-center shadow-lg shadow-cyan-500/20 group-hover:shadow-cyan-500/40 transition-all duration-300">
            <i class="fa-solid fa-book-open text-white text-base"></i>
          </div>
          <span class="text-white font-extrabold text-xl tracking-tight">مكتبة <span class="gradient-text">مدار</span></span>
        </a>
        <div class="hidden md:flex items-center gap-8">
          <a href="/" class="text-slate-400 text-sm font-medium hover:text-cyan-400 transition-colors duration-200">الرئيسية</a>
          <a href="/#grades" class="text-slate-400 text-sm font-medium hover:text-cyan-400 transition-colors duration-200">الصفوف</a>
        </div>
        <a href="https://madarcore.onrender.com"
           class="hidden sm:inline-flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-semibold text-cyan-300 border border-cyan-500/20 bg-cyan-500/5 hover:bg-cyan-500/15 hover:border-cyan-500/40 transition-all duration-300 shrink-0">
          <i class="fa-solid fa-arrow-right text-xs"></i>
          <span>الرجوع للموقع</span>
        </a>
      </div>
    </nav>

    <!-- Main Content -->
    <div class="relative z-10">
      <slot />
    </div>

    <!-- Footer -->
    <footer class="relative z-10 border-t border-slate-800/50 mt-20">
      <div class="max-w-6xl mx-auto px-4 py-10">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <div class="flex items-center gap-2.5">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-cyan-400 to-indigo-600 flex items-center justify-center">
              <i class="fa-solid fa-book-open text-white text-xs"></i>
            </div>
            <span class="text-white font-bold text-sm">مكتبة <span class="gradient-text">مدار</span></span>
          </div>
          <p class="text-slate-600 text-sm font-medium">جميع الكتب متاحة للتحميل المجاني &copy; {new Date().getFullYear()}</p>
        </div>
      </div>
    </footer>
  </body>
</html>
