---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

export interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalSlug?: string;
}

const { title, description, image, canonicalSlug } = Astro.props;
const site = 'https://madarlib.pages.dev';
const canonicalUrl = canonicalSlug ? `${site}${canonicalSlug}` : site;
const ogImage = image || `${site}/logo.webp`;
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="theme-color" content="#020617" />

    <!-- ClientRouter — enables SPA view transitions (replaces deprecated ViewTransitions) -->
    <ClientRouter fallback="swap" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/webp" href="/logo.webp" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  </head>
  <body>
    <!-- Floating Orbs -->
    <div class="fixed inset-0 pointer-events-none z-0 overflow-hidden" aria-hidden="true">
      <div class="absolute -top-40 -right-40 w-72 sm:w-96 h-72 sm:h-96 bg-cyan-500/8 rounded-full blur-[100px] animate-float"></div>
      <div class="absolute -bottom-40 -left-40 w-80 sm:w-[30rem] h-80 sm:h-[30rem] bg-indigo-500/8 rounded-full blur-[120px] animate-float-delayed"></div>
      <div class="absolute top-1/3 left-1/4 w-48 sm:w-64 h-48 sm:h-64 bg-blue-500/5 rounded-full blur-[80px] animate-float" style="animation-delay: 1.8s;"></div>
    </div>

    <!-- Navbar -->
    <nav class="relative z-50 nav-safe">
      <div class="glass-strong fixed top-3 sm:top-4 left-1/2 -translate-x-1/2 w-[calc(100%-1.25rem)] sm:w-[calc(100%-2rem)] max-w-6xl rounded-xl sm:rounded-2xl px-4 sm:px-6 py-2.5 sm:py-3 flex items-center justify-between shadow-2xl shadow-cyan-500/5">
        <a href="/" class="flex items-center gap-2 sm:gap-3 group shrink-0">
          <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg sm:rounded-xl bg-gradient-to-br from-cyan-400 to-indigo-600 flex items-center justify-center shadow-lg shadow-cyan-500/15 group-hover:shadow-cyan-500/35 transition-shadow duration-300">
            <i class="fa-solid fa-book-open text-white text-sm sm:text-lg"></i>
          </div>
          <span class="text-white font-bold text-base sm:text-xl tracking-tight">مكتبة <span class="gradient-text">مدار</span></span>
        </a>
        <div class="hidden md:flex items-center gap-6">
          <a href="/" class="text-slate-400 text-sm hover:text-cyan-400 transition-colors duration-200">الرئيسية</a>
          <a href="/" class="text-slate-400 text-sm hover:text-cyan-400 transition-colors duration-200">الصفوف</a>
        </div>
        <a href="https://madarcore.onrender.com"
           class="hidden sm:inline-flex items-center gap-2 px-3 sm:px-4 py-2 rounded-lg sm:rounded-xl text-xs sm:text-sm font-medium text-cyan-300 border border-cyan-500/20 bg-cyan-500/5 hover:bg-cyan-500/15 hover:border-cyan-500/40 hover:shadow-lg hover:shadow-cyan-500/10 transition-all duration-300 shrink-0">
          <i class="fa-solid fa-arrow-right text-[10px] sm:text-xs"></i>
          <span class="hidden xs:inline">الرجوع للموقع</span>
        </a>
      </div>
    </nav>

    <!-- Main Content -->
    <div class="relative z-10">
      <slot />
    </div>

    <!-- Footer -->
    <footer class="relative z-10 border-t border-slate-800/60 mt-16">
      <div class="max-w-6xl mx-auto px-4 py-8 sm:py-12">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-cyan-400 to-indigo-600 flex items-center justify-center">
              <i class="fa-solid fa-book-open text-white text-xs"></i>
            </div>
            <span class="text-white font-bold text-sm">مكتبة <span class="gradient-text">مدار</span></span>
          </div>
          <p class="text-slate-500 text-xs sm:text-sm">جميع الكتب متاحة للتحميل المجاني &copy; {new Date().getFullYear()}</p>
        </div>
      </div>
    </footer>
  </body>
</html>
