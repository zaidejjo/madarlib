---
interface Props {
  subject: string;
  code: string;
  icon: string;
  coverGradient: string;
  semesters: Array<{ term: number; label: string; studentBook?: { url: string }; activityBook?: { url: string } | null }>;
  gradeNumber: number;
}

const { subject, code, icon, coverGradient, semesters, gradeNumber } = Astro.props;
---

<a
  href={`/grade/${gradeNumber}/${code}`}
  class="group block glass rounded-2xl overflow-hidden border border-slate-800/60 hover:border-cyan-500/20 transition-all duration-300 hover:shadow-lg hover:shadow-cyan-500/5"
>
  <!-- Cover gradient area -->
  <div class={`h-28 sm:h-32 bg-gradient-to-br ${coverGradient} flex items-center justify-center relative overflow-hidden`}>
    <div class="absolute inset-0 bg-black/20"></div>
    <i class={`fa-solid ${icon} text-white/60 text-3xl sm:text-4xl group-hover:scale-110 transition-transform duration-300`}></i>
  </div>

  <!-- Content -->
  <div class="p-3 sm:p-4">
    <h3 class="text-white text-sm sm:text-base font-bold mb-2 truncate">{subject}</h3>
    <div class="flex flex-wrap gap-1.5">
      {semesters.map(sem => (
        <span class="px-2 py-0.5 rounded-full text-[10px] sm:text-xs font-medium bg-slate-800 text-slate-400 border border-slate-700/50">
          {sem.label}
        </span>
      ))}
    </div>
  </div>

  <!-- Hover indicator -->
  <div class="h-0.5 bg-gradient-to-r from-cyan-500 to-indigo-600 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-right"></div>
</a>
