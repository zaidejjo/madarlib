---
interface Props {
  subject: string;
  code: string;
  icon: string;
  coverGradient: string;
  semesters: Array<{ term: number; label: string; studentBook?: { url: string }; activityBook?: { url: string } | null }>;
  gradeNumber: number;
}

const { subject, code, icon, coverGradient, semesters, gradeNumber } = Astro.props;
---

<a
  href={`/grade/${gradeNumber}/${code}`}
  data-astro-prefetch
  class="book-card group block glass rounded-2xl overflow-hidden border border-slate-800/50"
>
  <!-- Cover gradient area -->
  <div class={`h-28 sm:h-32 bg-gradient-to-br ${coverGradient} flex items-center justify-center relative overflow-hidden`}>
    <div class="absolute inset-0 bg-black/15 group-hover:bg-black/5 transition-colors duration-300"></div>
    <i class={`fa-solid ${icon} text-white/50 text-3xl sm:text-4xl group-hover:scale-110 group-hover:text-white/70 transition-all duration-300`}></i>
  </div>

  <!-- Content -->
  <div class="p-4 sm:p-5">
    <h3 class="text-white text-sm sm:text-base font-bold mb-2.5 truncate">{subject}</h3>
    <div class="flex flex-wrap gap-1.5">
      {semesters.map(sem => (
        <span class="px-2.5 py-0.5 rounded-full text-[10px] sm:text-xs font-semibold bg-slate-800/80 text-slate-400 border border-slate-700/50">
          {sem.label}
        </span>
      ))}
    </div>
  </div>

  <!-- Hover accent bar -->
  <div class="h-0.5 bg-gradient-to-r from-cyan-500 to-indigo-600 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-right"></div>
</a>
