---
interface Props {
  subject: string;
  code: string;
  icon: string;
  coverGradient: string;
  semesters: Array<{ term: number; label: string; studentBook?: { url: string }; activityBook?: { url: string } | null }>;
  gradeNumber: number;
}

const { subject, code, icon, coverGradient, semesters, gradeNumber } = Astro.props;
---

<a
  href={`/grade/${gradeNumber}/${code}`}
  data-astro-prefetch
  class="book-card block rounded-2xl overflow-hidden border"
  style="border-color: var(--border);"
>
  <!-- Cover gradient area -->
  <div class={`h-28 sm:h-32 bg-gradient-to-br ${coverGradient} flex items-center justify-center relative overflow-hidden`}>
    <div class="absolute inset-0 bg-black/15 group-hover:bg-black/5 transition-colors duration-300"></div>
    <i class={`fa-solid ${icon} text-white/50 text-3xl sm:text-4xl group-hover:scale-110 group-hover:text-white/70 transition-all duration-300`}></i>
  </div>

  <!-- Content -->
  <div class="p-4 sm:p-5" style="background-color: var(--surface);">
    <h3 class="text-sm sm:text-base font-bold mb-2.5 truncate" style="color: var(--text);">{subject}</h3>
    <div class="flex flex-wrap gap-1.5">
      {semesters.map(sem => (
        <span class="px-2.5 py-0.5 rounded-full text-[10px] sm:text-xs font-semibold border"
              style="color: var(--text-muted); background-color: var(--surface-hover); border-color: var(--border);">
          {sem.label}
        </span>
      ))}
    </div>
  </div>
</a>
