---
interface Props {
  number: number;
  nameArabic: string;
  nameEnglish: string;
  cardBg: string;
  iconGradient: string;
  badgeClass: string;
  arrowCSS: string;
  bookCount: number;
}

const { number, nameArabic, nameEnglish, bookCount } = Astro.props;

function toArabicNum(n: number): string {
  const arabicDigits = ['٠', '١', '٢', '٣', '٤', '٥', '٦', '٧', '٨', '٩'];
  return String(n).split('').map(c => arabicDigits[parseInt(c)] || c).join('');
}
---

<a
  href={`/grade/${number}`}
  data-astro-prefetch
  class="grade-card group rounded-2xl sm:rounded-3xl overflow-hidden p-6 sm:p-7 flex flex-col justify-between text-right w-full"
>
  <!-- Top row -->
  <div class="relative flex items-start justify-between z-10">
    <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-xl sm:rounded-2xl flex items-center justify-center text-white text-lg sm:text-xl shadow-sm shrink-0 surface-hover"
         style="color: var(--text-muted);">
      <i class="fa-solid fa-graduation-cap"></i>
    </div>
    <span class="px-3 py-1 rounded-full text-xs sm:text-sm font-bold border surface-hover"
          style="color: var(--text-muted); border-color: var(--border);">
      {toArabicNum(bookCount)} كتب
    </span>
  </div>

  <!-- Bottom row -->
  <div class="relative z-10 mt-auto">
    <p class="text-xs sm:text-sm font-medium mb-0.5" style="color: var(--text-muted);">الصف</p>
    <h3 class="text-2xl sm:text-3xl font-black mb-0.5" style="color: var(--text);">{nameArabic}</h3>
    <p class="text-xs sm:text-sm font-medium" style="color: var(--text-subtle);">{nameEnglish}</p>
  </div>

  <!-- Arrow icon — neutral, fades in on hover -->
  <div class="absolute bottom-6 sm:bottom-7 left-6 sm:left-7 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-2 group-hover:translate-x-0 z-10"
       style="color: var(--text-muted);">
    <i class="fa-solid fa-arrow-left text-xl sm:text-2xl"></i>
  </div>
</a>
