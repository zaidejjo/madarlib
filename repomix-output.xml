  <script>
    // Helper for Arabic numerals
    function toArabicNumeral(n) {
      var digits = '٠١٢٣٤٥٦٧٨٩';
      return String(n).split('').map(function(c) {
        return digits[parseInt(c, 10)] || c;
      }).join('');
    }

    function app() {
      return {
        grades: [],
        isLoading: true,
        mobileMenuOpen: false,

        async init() {
          console.log('Dashboard: Initializing...');
          try {
            // Add cache-buster to ensure fresh data
            const response = await fetch('books.json?t=' + Date.now());
            if (!response.ok) {
              throw new Error('HTTP error! status: ' + response.status);
            }
            const data = await response.json();
            console.log('Dashboard: Data loaded:', data);

            if (data && Array.isArray(data.grades)) {
              this.grades = data.grades.map(g => ({
                ...g,
                // Calculate book count safely
                bookCount: g.books ? g.books.reduce((acc, b) => acc + b.semesters.length, 0) : 0
              }));
              console.log('Dashboard: Grades processed:', this.grades.length);
            } else {
              console.error('Dashboard: Invalid data structure. Expected "grades" array.');
              this.grades = [];
            }
          } catch (e) {
            console.error('Dashboard: Failed to load books.json:', e);
            this.grades = []; // Ensure empty array on failure
          } finally {
            this.isLoading = false;
            console.log('Dashboard: Loading state set to false.');
          }
        },

        selectGrade(grade) {
          console.log('Dashboard: Navigating to grade', grade.number);
          window.location.href = `book.html?grade=${grade.number}`;
        },

        toArNum(n) {
          return toArabicNumeral(n);
        }
      };
    }
  </script>
</body>
