  <script>
    (function() {
      'use strict';

      const semesterColors = {
        1: { bg: 'bg-emerald-500/10', border: 'border-emerald-500/20', text: 'text-emerald-300', shadow: 'shadow-emerald-500/5' },
        2: { bg: 'bg-amber-500/10',   border: 'border-amber-500/20',   text: 'text-amber-300',   shadow: 'shadow-amber-500/5' }
      };

      let currentGradeData = null;
      let allBooksData = [];

      async function init() {
        const params = new URLSearchParams(window.location.search);
        const gradeNum = params.get('grade');

        if (!gradeNum || isNaN(gradeNum) || gradeNum < 1 || gradeNum > 12) {
          showError('الصف غير موجود', 'الرجاء اختيار صف من 1 إلى 12');
          return;
        }

        showSkeletons();

        try {
          const response = await fetch('books.json');
          if (!response.ok) throw new Error('Network response was not ok');
          const data = await response.json();
          
          const grade = data.grades.find(g => g.number == gradeNum);
          if (!grade) {
            showError('بيانات الصف غير متوفرة', 'نعتذر، لم يتم العثور على بيانات لهذا الصف في قاعدة البيانات');
            return;
          }

          currentGradeData = grade;
          allBooksData = grade.books;
          
          setupPageMetadata(grade);
          setupVisuals(grade);
          renderFilters();
          renderBooks('all');
          setupMobileMenu();
          
          document.getElementById('filterSection').classList.remove('js-hidden');
          document.getElementById('booksSection').classList.remove('js-hidden');
        } catch (error) {
          console.error('Fetch error:', error);
          showError('حدث خطأ أثناء تحميل البيانات', 'يرجى التحقق من اتصالك بالإنترنت والمحاولة مرة أخرى');
        }
      }

      function setupPageMetadata(grade) {
        const name = grade.nameArabic;
        document.title = `كتب الصف ${name} | مكتبة مدار`;
        document.getElementById('metaDesc').content = `كتب الصف ${name} - مكتبة مدار الرقمية`;
        document.getElementById('navGradeText').textContent = `الصف ${name}`;
        document.getElementById('breadcrumbGrade').textContent = `الصف ${name}`;
        document.getElementById('headerTitle').textContent = `الصف ${name}`;
        document.getElementById('mobileGradeLabel').textContent = `الصف ${name}`;
        document.getElementById('footerGrade').textContent = `الصف ${name}`;
        
        const bookCount = grade.books.reduce((acc, b) => acc + b.semesters.length, 0);
        document.getElementById('headerBadge').textContent = `الصف ${name} - ${bookCount} كتب متاحة`;
      }

      function setupVisuals(grade) {
        document.body.classList.add(`accent-${grade.accentColor}`);
      }

      function showSkeletons() {
        const grid = document.getElementById('booksGrid');
        grid.innerHTML = '';
        for (let i = 0; i < 8; i++) {
          grid.innerHTML += `
            <div class="book-card rounded-xl sm:rounded-2xl overflow-hidden bg-slate-900/50 border border-slate-800/50 flex flex-col animate-pulse">
              <div class="h-36 sm:h-40 md:h-44 bg-slate-800 animate-shimmer"></div>
              <div class="p-4 sm:p-5 flex flex-col flex-1 gap-4">
                <div class="flex justify-between">
                  <div class="h-3 w-16 bg-slate-800 rounded"></div>
                  <div class="h-3 w-12 bg-slate-800 rounded-full"></div>
                </div>
                <div class="h-5 w-3/4 bg-slate-800 rounded"></div>
                <div class="h-3 w-1/2 bg-slate-800 rounded mb-4"></div>
                <div class="mt-auto h-11 w-full bg-slate-800 rounded-lg"></div>
              </div>
            </div>
          `;
        }
      }

      function renderFilters() {
        const container = document.getElementById('filterContainer');
        const subjects = [];
        const seen = new Set();
        
        currentGradeData.books.forEach(b => {
          if (!seen.has(b.code)) {
            subjects.push(b);
            seen.add(b.code);
          }
        });

        let html = `
          <button class="filter-pill active px-3 sm:px-5 py-2 sm:py-2.5 rounded-lg sm:rounded-xl text-xs sm:text-sm font-medium 
            bg-cyan-500/15 border border-cyan-500/50 text-cyan-300 shadow-lg shadow-cyan-500/5" 
            data-filter="all" onclick="window.filterBooks('all')" type="button">
            <i class="fa-solid fa-layer-group ml-1 sm:ml-1.5 text-[10px] sm:text-xs"></i> الكل
          </button>
        `;

        subjects.forEach(s => {
          html += `
            <button class="filter-pill px-3 sm:px-5 py-2 sm:py-2.5 rounded-lg sm:rounded-xl text-xs sm:text-sm font-medium 
              border border-slate-700 text-slate-400 hover:text-cyan-300 hover:border-cyan-500/30 hover:bg-cyan-500/5" 
              data-filter="${s.code}" onclick="window.filterBooks('${s.code}')" type="button">
              <i class="fa-solid ${s.icon} ml-1 sm:ml-1.5 text-[10px] sm:text-xs"></i> ${s.subject}
            </button>
          `;
        });

        container.innerHTML = html;
      }

      function renderBooks(filter) {
        const grid = document.getElementById('booksGrid');
        grid.innerHTML = '';
        let visibleCount = 0;
        let idx = 0;

        currentGradeData.books.forEach(book => {
          if (filter !== 'all' && book.code !== filter) return;

          book.semesters.forEach(sem => {
            idx++;
            visibleCount++;
            const sc = semesterColors[sem.term] || semesterColors[1];
            const entranceCls = `entrance-${Math.min(idx, 12)}`;

            const card = document.createElement('div');
            card.className = `book-card rounded-xl sm:rounded-2xl overflow-hidden bg-gradient-to-b from-slate-900/90 to-slate-950/90 border border-slate-800/50 shadow-lg shadow-slate-900/50 hover:shadow-xl flex flex-col ${entranceCls}`;
            card.dataset.subject = book.code;
            card.innerHTML = `
              <div class="book-cover h-36 sm:h-40 md:h-44 bg-gradient-to-br ${book.coverGradient} flex items-center justify-center">
                <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-xl sm:rounded-2xl bg-white/5 backdrop-blur-sm border border-white/10 flex items-center justify-center">
                  <i class="fa-solid ${book.icon} text-white/80 text-2xl sm:text-3xl"></i>
                </div>
              </div>
              <div class="p-4 sm:p-5 flex flex-col flex-1">
                <div class="flex items-center justify-between mb-2 sm:mb-3">
                  <span class="text-slate-400 text-[10px] sm:text-xs font-medium">${book.subject}</span>
                  <span class="px-2 sm:px-2.5 py-0.5 rounded-full ${sc.bg} border ${sc.border} ${sc.text} text-[10px] sm:text-xs font-semibold shadow-sm ${sc.shadow}">
                    <i class="fa-solid fa-star ml-1 text-[8px] sm:text-[10px]"></i> ${sem.label}
                  </span>
                </div>
                <h3 class="text-white font-bold text-sm sm:text-base mb-0.5 sm:mb-1">${book.subject}</h3>
                <p class="text-slate-500 text-[10px] sm:text-xs mb-3 sm:mb-4">للصف ${currentGradeData.nameArabic} - ${sem.label}</p>
                <div class="mt-auto">
                  <a download="${sem.url}" href="${sem.url}" target="_blank" 
                     class="btn-download btn-download-accent group flex items-center justify-center gap-2 w-full px-3 sm:px-4 py-2.5 sm:py-3 
                            rounded-lg sm:rounded-xl text-xs sm:text-sm font-bold min-h-[44px] 
                            bg-gradient-to-r from-slate-700/40 to-slate-800/30 
                            border border-slate-600/30 text-slate-300 
                            active:scale-[0.98] transition-all duration-300">
                    <i class="fa-solid fa-download group-hover:-translate-y-0.5 transition-transform text-[10px] sm:text-xs"></i>
                    <span>تحميل الكتاب</span>
                  </a>
                </div>
              </div>
            `;
            grid.appendChild(card);
          });
        });

        document.getElementById('emptyState').classList.toggle('hidden', visibleCount > 0);
      }

      window.filterBooks = function(subjectKey) {
        const pills = document.querySelectorAll('.filter-pill');
        pills.forEach(pill => {
          if (pill.dataset.filter === subjectKey) {
            pill.classList.add('active', 'bg-cyan-500/15', 'border-cyan-500/50', 'text-cyan-300', 'shadow-lg', 'shadow-cyan-500/5');
          } else {
            pill.classList.remove('active', 'bg-cyan-500/15', 'border-cyan-500/50', 'text-cyan-300', 'shadow-lg', 'shadow-cyan-500/5');
          }
        });
        renderBooks(subjectKey);
      };

      function setupMobileMenu() {
        const menuBtn = document.getElementById('mobileMenuBtn');
        const mobileMenu = document.getElementById('mobileMenu');
        const closeBtn = document.getElementById('closeMobileMenu');
        const filterList = document.getElementById('mobileFilterList');

        menuBtn.onclick = () => {
          mobileMenu.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
        };
        closeBtn.onclick = () => {
          mobileMenu.classList.add('hidden');
          document.body.style.overflow = '';
        };

        const subjects = [];
        const seen = new Set();
        currentGradeData.books.forEach(b => {
          if (!seen.has(b.code)) {
            subjects.push(b);
            seen.add(b.code);
          }
        });

        let mfHTML = `<button class="px-4 py-2 rounded-full border border-slate-700 text-slate-300 text-sm hover:border-cyan-500/40 transition-colors" onclick="window.filterBooks('all'); document.getElementById('mobileMenu').classList.add('hidden'); document.body.style.overflow='';">الكل</button>`;
        subjects.forEach(s => {
          mfHTML += `<button class="px-4 py-2 rounded-full border border-slate-700 text-slate-300 text-sm hover:border-cyan-500/40 transition-colors" onclick="window.filterBooks('${s.code}'); document.getElementById('mobileMenu').classList.add('hidden'); document.body.style.overflow='';">
            <i class="fa-solid ${s.icon} ml-1.5"></i> ${s.subject}
          </button>`;
        });
        filterList.innerHTML = mfHTML;
      }

      function showError(title, message) {
        const section = document.getElementById('booksSection');
        section.innerHTML = `
          <div class="max-w-6xl mx-auto flex items-center justify-center py-20">
            <div class="glass-strong p-8 rounded-3xl text-center max-w-md border-red-500/20 shadow-2xl shadow-red-500/10">
              <div class="w-20 h-20 rounded-full bg-red-500/10 border border-red-500/20 flex items-center justify-center mx-auto mb-6">
                <i class="fa-solid fa-circle-exclamation text-red-400 text-3xl"></i>
              </div>
              <h3 class="text-2xl font-bold text-white mb-3">${title}</h3>
              <p class="text-slate-400 mb-8 leading-relaxed">${message}</p>
              <a href="index.html" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl bg-slate-800 border border-slate-700 text-slate-300 font-medium hover:bg-slate-700 transition-all duration-200">
                <i class="fa-solid fa-arrow-right"></i> العودة للرئيسية
              </a>
            </div>
          </div>
        `;
        document.getElementById('filterSection').classList.add('hidden');
        document.getElementById('booksSection').classList.remove('js-hidden');
      }

      init();
    })();
  </script>
</body>
</html>
